# ════════════════════════════════════════════════════════════════
# mini-mall-cloud .gitignore
# ════════════════════════════════════════════════════════════════

# --- Maven 构建产物 ---
target/
*.jar
*.war
*.class

# --- IDE 配置 ---
.idea/
*.iml
*.iws
*.ipr
.vscode/
.project
.classpath
.settings/
.factorypath

# --- 日志 ---
*.log
logs/
log/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- ⭐ 含密码的 application.yml (4 个微服务全部排除) ---
# 提交对应的 application.yml.example 给读者参考
mini-mall-gateway/src/main/resources/application.yml
mini-mall-order/src/main/resources/application.yml
mini-mall-product/src/main/resources/application.yml
mini-mall-user/src/main/resources/application.yml

# --- 临时文件 ---
*.tmp
*.swp
*~
.~*

# --- Spring Boot ---
HELP.md
spring-boot-*.log

# --- 其他敏感文件 ---
*.pem
*.key
*.p12
.env
.env.local
